# chalk -- Caddyfile (generated by chalkctl init). Do not edit by hand;
# re-run chalkctl to regenerate. Stock Caddy: no tls block => HTTP-01.
{{ .Domain }} {
	encode zstd gzip
	reverse_proxy chalkd:8443 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
	handle_errors {
		respond "chalk is taking a moment, try again" 503
	}
}
