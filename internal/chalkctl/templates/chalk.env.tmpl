# chalk -- secrets + host config (generated by chalkctl init). chmod 600.
# Values are LITERAL (no ${...} cross-references): systemd/Quadlet expands
# Environment= lines before EnvironmentFile= loads, so composed vars must be
# fully resolved here, read directly by chalkd.
CHALK_PG_PASSWORD={{ .PGPassword }}
CHALK_DB_URL=postgres://chalk:{{ .PGPassword }}@postgres:5432/chalk?sslmode=disable
{{- if .VoiceEnabled }}
CHALK_TURN_SECRET={{ .TurnSecret }}
{{- end }}
