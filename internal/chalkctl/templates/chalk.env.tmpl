# chalk -- secrets + host config (generated by chalkctl init). chmod 600.
# All values are LITERAL. systemd/Quadlet expands Environment= lines BEFORE
# EnvironmentFile= loads, so NOTHING here may be a dollar-brace cross-reference and
# NO unit may compose a value from another env var -- each container reads its
# values straight from this file.

# --- database ---
CHALK_PG_PASSWORD={{ .PGPassword }}
POSTGRES_PASSWORD={{ .PGPassword }}
CHALK_DB_URL=postgres://chalk:{{ .PGPassword }}@postgres:5432/chalk?sslmode=disable

# --- WebAuthn / passkeys (RP ID MUST equal the domain; origins the https URL) ---
CHALK_RP_ID={{ .Domain }}
CHALK_RP_NAME=chalk
CHALK_RP_ORIGINS=https://{{ .Domain }}

# --- admin seed (first boot only; enroll a passkey onto this row at the site) ---
CHALK_ADMIN_USERNAME={{ .AdminUsername }}
CHALK_ADMIN_EMAIL={{ .AdminEmail }}

# --- registration (bootstrap: let friends sign up; set false once everyone's in) ---
CHALK_OPEN_REGISTRATION={{ .OpenRegistration }}
{{- if .VoiceEnabled }}

# --- voice ---
CHALK_TURN_SECRET={{ .TurnSecret }}
{{- if gt .VoiceMaxParticipants 0 }}
CHALK_VOICE_MAX_PARTICIPANTS={{ .VoiceMaxParticipants }}
{{- end }}
{{- end }}
{{- if gt .AttachMaxBytes 0 }}

# --- attachments ---
CHALK_ATTACH_MAX_BYTES={{ .AttachMaxBytes }}
{{- end }}
{{- if .GiphyAPIKey }}

# --- giphy ---
CHALK_GIPHY_API_KEY={{ .GiphyAPIKey }}
{{- end }}
