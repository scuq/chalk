# chalk -- secrets + host config (generated by chalkctl init). chmod 600.
# All values are LITERAL. systemd/Quadlet expands Environment= lines BEFORE
# EnvironmentFile= loads, so NOTHING here may be a dollar-brace cross-reference and
# NO unit may compose a value from another env var -- each container reads its
# values straight from this file.
CHALK_PG_PASSWORD={{ .PGPassword }}
POSTGRES_PASSWORD={{ .PGPassword }}
CHALK_DB_URL=postgres://chalk:{{ .PGPassword }}@postgres:5432/chalk?sslmode=disable
{{- if .VoiceEnabled }}
CHALK_TURN_SECRET={{ .TurnSecret }}
{{- end }}
