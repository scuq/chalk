# chalk -- coturn config (generated by chalkctl init). Literal secret; no env
# expansion. Plain turn: only (media is DTLS-SRTP E2E regardless).
listening-port=3478
min-port=49160
max-port=49200
realm=chalk
use-auth-secret
static-auth-secret={{ .TurnSecret }}
fingerprint
no-cli
no-tls
no-dtls
log-file=stdout
