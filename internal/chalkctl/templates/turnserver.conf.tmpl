# chalk -- coturn config (generated by chalkctl init). Literal secret; no env
# expansion. Plain turn: only (media is DTLS-SRTP E2E regardless).
#
# Logging is set on the CLI in the unit (-n and the stdout log flags), NOT in
# this file -- a config-file logging directive is what coturn's rotating logger
# hijacks. Same for the external / relay IP: the image's DETECT_EXTERNAL_IP /
# DETECT_RELAY_IP env vars add those flags at runtime (IPv4, auto-detected),
# so they are not pinned here either.
listening-port=3478
min-port=49160
max-port=49200
realm=chalk
use-auth-secret
static-auth-secret={{ .TurnSecret }}
fingerprint
no-cli
no-tls
no-dtls
