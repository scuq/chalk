package pubsub

import (
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"strings"
	"sync"
	"time"

	"github.com/jackc/pgx/v5/pgconn"
	"github.com/jackc/pgx/v5/pgxpool"
)

// Handler is invoked once per received Event. Implementations should be
// fast and non-blocking; long work belongs in a separate goroutine.
type Handler func(Event)

// Listener holds a dedicated Postgres connection that runs LISTEN and
// dispatches notifications to a Handler. The connection is held outside the
// pool because pgx pools cannot be used for LISTEN: a pooled connection
// might be returned and reused by another query, dropping pending
// notifications.
//
// Phase 08 extends the listener with dynamic subscription: in addition to
// the always-on chalk_global topic, callers can Subscribe(topic) and
// Unsubscribe(topic) on a refcounted set of per-channel topics. The
// dedicated conn stays single-goroutine-owned -- subscribe/unsubscribe
// commands are queued on a buffered channel and applied between
// notification waits.
//
// Concurrency model: Subscribe/Unsubscribe touch a refcount map under
// subMu, then drop a subCmd onto l.cmds. The Run goroutine owns the
// hijacked conn; it pumps notifications via WaitForNotification with a
// short timeout (cmdPollInterval). On timeout, it drains pending cmds.
// On a real notification, it dispatches first, then drains cmds, then
// loops. This guarantees pgconn.PgConn is only ever touched by Run.
type Listener struct {
	pool    *pgxpool.Pool
	handler Handler
	logf    func(string, ...any)

	// Tunables.
	BackoffInitial time.Duration
	BackoffMax     time.Duration
	// CmdPollInterval bounds how long Subscribe blocks waiting for the
	// listener goroutine to apply a LISTEN. Smaller = lower latency but
	// more idle CPU; larger = batchier. 50ms is a good default.
	CmdPollInterval time.Duration

	readyOnce sync.Once
	ready     chan struct{}

	subMu     sync.Mutex
	subCounts map[string]int

	cmds chan subCmd
}

type subCmd struct {
	op    string // "sub" or "unsub"
	topic string
	done  chan error // nil for fire-and-forget unsub
}

// NewListener constructs a Listener. pool must NOT have its connections
// re-used for unrelated queries -- the listener acquires and hijacks one
// connection for its lifetime.
func NewListener(pool *pgxpool.Pool, handler Handler, logf func(string, ...any)) *Listener {
	if logf == nil {
		logf = func(string, ...any) {}
	}
	return &Listener{
		pool:            pool,
		handler:         handler,
		logf:            logf,
		BackoffInitial:  250 * time.Millisecond,
		BackoffMax:      10 * time.Second,
		CmdPollInterval: 50 * time.Millisecond,
		ready:           make(chan struct{}),
		subCounts:       make(map[string]int),
		cmds:            make(chan subCmd, 64),
	}
}

// Ready returns a channel closed when the listener has subscribed to
// chalk_global at least once.
func (l *Listener) Ready() <-chan struct{} { return l.ready }

// Subscribe increments the refcount for topic and issues LISTEN if this
// is the first reference. Idempotent across multiple callers; only the
// LAST Unsubscribe matching a Subscribe triggers UNLISTEN.
//
// Blocks until the LISTEN has been applied by the listener goroutine
// (or returns ctx.Err()). Safe to call concurrently.
func (l *Listener) Subscribe(ctx context.Context, topic string) error {
	if topic == "" {
		return errors.New("pubsub: empty topic")
	}
	if !validTopic(topic) {
		return fmt.Errorf("pubsub: invalid topic name %q", topic)
	}

	l.subMu.Lock()
	l.subCounts[topic]++
	count := l.subCounts[topic]
	l.subMu.Unlock()

	if count != 1 {
		return nil // someone else already subscribed
	}

	done := make(chan error, 1)
	select {
	case l.cmds <- subCmd{op: "sub", topic: topic, done: done}:
	case <-ctx.Done():
		l.rollbackSub(topic)
		return ctx.Err()
	}
	select {
	case err := <-done:
		if err != nil {
			l.rollbackSub(topic)
		}
		return err
	case <-ctx.Done():
		return ctx.Err()
	}
}

// rollbackSub decrements a refcount that was optimistically incremented
// by Subscribe. Used when the LISTEN command failed or ctx was canceled.
func (l *Listener) rollbackSub(topic string) {
	l.subMu.Lock()
	l.subCounts[topic]--
	if l.subCounts[topic] <= 0 {
		delete(l.subCounts, topic)
	}
	l.subMu.Unlock()
}

// Unsubscribe decrements the refcount and queues UNLISTEN if the
// refcount reaches zero. Non-blocking. Safe to call concurrently.
func (l *Listener) Unsubscribe(topic string) {
	if topic == "" {
		return
	}
	l.subMu.Lock()
	if l.subCounts[topic] == 0 {
		l.subMu.Unlock()
		return
	}
	l.subCounts[topic]--
	count := l.subCounts[topic]
	if count <= 0 {
		delete(l.subCounts, topic)
	}
	l.subMu.Unlock()
	if count != 0 {
		return
	}
	select {
	case l.cmds <- subCmd{op: "unsub", topic: topic, done: nil}:
	default:
		l.logf("listener: cmd queue full; dropping UNLISTEN %s", topic)
	}
}

// SubscriptionCounts returns a snapshot of the current refcount map.
// For tests and ops endpoints.
func (l *Listener) SubscriptionCounts() map[string]int {
	l.subMu.Lock()
	defer l.subMu.Unlock()
	out := make(map[string]int, len(l.subCounts))
	for k, v := range l.subCounts {
		out[k] = v
	}
	return out
}

// Run blocks until ctx is canceled, dispatching every received event
// through the handler. On connection errors it reconnects with exponential
// backoff capped at BackoffMax. After reconnect, all previously-subscribed
// topics are re-issued (their refcounts persist across connection loss).
func (l *Listener) Run(ctx context.Context) error {
	backoff := l.BackoffInitial
	for {
		err := l.runOnce(ctx)
		if err == nil {
			return ctx.Err()
		}
		if errors.Is(err, context.Canceled) || errors.Is(err, context.DeadlineExceeded) {
			return ctx.Err()
		}
		l.logf("listener error: %v; reconnecting in %s", err, backoff)
		select {
		case <-ctx.Done():
			return ctx.Err()
		case <-time.After(backoff):
		}
		backoff *= 2
		if backoff > l.BackoffMax {
			backoff = l.BackoffMax
		}
	}
}

// runOnce acquires a dedicated connection, issues LISTEN on chalk_global
// plus every refcounted topic, and pumps notifications + subscription
// commands until either the connection drops or ctx is canceled.
//
// Returns nil only on clean ctx cancellation.
func (l *Listener) runOnce(ctx context.Context) error {
	conn, err := l.pool.Acquire(ctx)
	if err != nil {
		return fmt.Errorf("acquire conn: %w", err)
	}
	hijacked := conn.Hijack()
	defer hijacked.Close(context.Background())

	// Always LISTEN on chalk_global (friend/presence events).
	if _, err := hijacked.Exec(ctx, `LISTEN `+Channel).ReadAll(); err != nil {
		return fmt.Errorf("LISTEN %s: %w", Channel, err)
	}
	l.logf("listener subscribed to %s", Channel)

	// Re-subscribe to per-channel topics with positive refcount. On
	// initial run this map is empty; on reconnect it contains every
	// topic the server code subscribed to before the disconnect.
	l.subMu.Lock()
	topics := make([]string, 0, len(l.subCounts))
	for t := range l.subCounts {
		topics = append(topics, t)
	}
	l.subMu.Unlock()
	for _, t := range topics {
		if _, err := hijacked.Exec(ctx, `LISTEN `+quoteIdent(t)).ReadAll(); err != nil {
			l.logf("listener: re-LISTEN %s failed: %v", t, err)
		}
	}

	l.readyOnce.Do(func() { close(l.ready) })

	// Main pump loop. WaitForNotification with a short timeout serves
	// as our poll mechanism; on timeout we drain the cmd queue. On a
	// real notification we dispatch + then drain cmds before looping.
	for {
		if err := ctx.Err(); err != nil {
			return nil
		}
		// Drain any pending commands before blocking on the next
		// notification. This minimizes Subscribe() latency: if a
		// caller queues a LISTEN while we're about to block, we
		// handle it before sleeping.
		if err := l.drainCmds(ctx, hijacked); err != nil {
			return err
		}

		pollCtx, cancel := context.WithTimeout(ctx, l.CmdPollInterval)
		notif, err := hijacked.WaitForNotification(pollCtx)
		cancel()
		if err != nil {
			// Timeout from our poll bound is expected. Anything else
			// is a real error.
			if errors.Is(err, context.DeadlineExceeded) {
				continue
			}
			if errors.Is(err, context.Canceled) {
				return nil
			}
			return fmt.Errorf("wait for notification: %w", err)
		}
		l.dispatch(notif)
	}
}

// drainCmds runs every queued subscribe/unsubscribe command without
// blocking. Returns an error only if a command's Exec fails AND the
// listener should reconnect; per-topic LISTEN failures are logged and
// the refcount stays in the map for retry on reconnect.
func (l *Listener) drainCmds(ctx context.Context, conn *pgconn.PgConn) error {
	for {
		select {
		case cmd := <-l.cmds:
			var execErr error
			switch cmd.op {
			case "sub":
				_, execErr = conn.Exec(ctx, `LISTEN `+quoteIdent(cmd.topic)).ReadAll()
				if execErr == nil {
					l.logf("listener subscribed to %s", cmd.topic)
				}
			case "unsub":
				_, execErr = conn.Exec(ctx, `UNLISTEN `+quoteIdent(cmd.topic)).ReadAll()
				if execErr == nil {
					l.logf("listener unsubscribed from %s", cmd.topic)
				}
			default:
				execErr = fmt.Errorf("unknown cmd op %q", cmd.op)
			}
			if cmd.done != nil {
				cmd.done <- execErr
			}
			if execErr != nil {
				l.logf("listener: %s %s: %v", cmd.op, cmd.topic, execErr)
				// If the conn is dead, return so Run reconnects.
				// We can't easily tell apart "conn dead" from
				// "LISTEN name was invalid"; assume any error
				// means we should reconnect.
				return execErr
			}
		default:
			return nil
		}
	}
}

// dispatch decodes a notification and invokes the handler.
func (l *Listener) dispatch(n *pgconn.Notification) {
	var ev Event
	if err := json.Unmarshal([]byte(n.Payload), &ev); err != nil {
		l.logf("listener: bad payload from PID %d: %v", n.PID, err)
		return
	}
	defer func() {
		if r := recover(); r != nil {
			l.logf("listener: handler panic: %v", r)
		}
	}()
	l.handler(ev)
}

// validTopic enforces what Postgres allows in LISTEN: ≤63 chars, ASCII
// letters/digits/underscore. We also forbid leading digits because
// Postgres identifiers don't allow them unquoted (we do quote, but
// keeping the rule simple).
func validTopic(t string) bool {
	if t == "" || len(t) > 63 {
		return false
	}
	for i, r := range t {
		if r == '_' || (r >= 'a' && r <= 'z') || (r >= 'A' && r <= 'Z') ||
			(i > 0 && r >= '0' && r <= '9') {
			continue
		}
		return false
	}
	return true
}

// quoteIdent wraps a topic in double quotes and escapes any embedded
// double quotes. We validate via validTopic before calling this; in
// practice no escaping ever happens, but defense-in-depth is cheap.
func quoteIdent(s string) string {
	return `"` + strings.ReplaceAll(s, `"`, `""`) + `"`
}
