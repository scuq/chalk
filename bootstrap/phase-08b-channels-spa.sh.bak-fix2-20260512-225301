#!/usr/bin/env bash
# bootstrap/phase-08b-channels-spa.sh
# Phase 08b: SPA channel UI + subscribe_channel protocol extension.
#
# Tests:
#   - go vet, unit tests, go build
#   - npm install + typecheck + bundle
#   - re-run phase 08a integration tests (they now use subscribe_channel
#     instead of reconnect)
#   - migration 0010 applies via chalkd --migrate-only
#   - seed the fixed-UUID devices that the Playwright spec uses
#   - run the channels.spec.ts Playwright spec against two chalkds

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
. "${SCRIPT_DIR}/lib/common.sh"
chalk_use_lib checks
chalk_use_lib postgres
chalk_use_lib testing
chalk_use_lib server
chalk_use_lib frontend

PHASE="08b"
PHASE_NAME="channels-spa"

phase_begin "$PHASE" "$PHASE_NAME"
require_phase "08"

phase_step "host environment"
checks_go_docker
web_check_node

phase_step "verifying expected files"
expected=(
  internal/proto/frames_phase08b.go
  internal/server/ws_phase08b.go
  web/src/state/types.ts
  web/src/state/reducer.ts
  web/src/components/App.tsx
  web/src/components/Sidebar.tsx
  web/src/components/CreateChannelModal.tsx
  web/src/components/FriendPicker.tsx
  test/e2e/channels.spec.ts
)
for f in "${expected[@]}"; do
  [ -f "${CHALK_REPO_ROOT}/${f}" ] || die "missing: ${f}"
done

phase_step "go mod tidy"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  cd "$CHALK_REPO_ROOT"
  go mod tidy
fi

phase_step "go vet"
go_vet_check

phase_step "npm install + typecheck (web)"
web_install
web_typecheck

phase_step "esbuild bundle"
web_build

phase_step "go test (unit)"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  cd "$CHALK_REPO_ROOT"
  go test -race -count=1 -short ./internal/...
fi

phase_step "go build"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  cd "$CHALK_REPO_ROOT"
  mkdir -p bin
  CGO_ENABLED=0 go build -trimpath \
    -ldflags="-s -w -X github.com/scuq/chalk/internal/version.Version=0.0.0-dev -X github.com/scuq/chalk/internal/version.Commit=phase08b" \
    -o bin/chalkd ./cmd/chalkd
fi

phase_step "spinning up ephemeral postgres"
pg_start_ephemeral
trap 'server_stop_all; server_dump_all_logs; pg_stop_ephemeral' EXIT

phase_step "applying migrations via chalkd --migrate-only"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  CHALK_DB_URL="$CHALK_TEST_PGURL" \
    "${CHALK_REPO_ROOT}/bin/chalkd" --migrate-only --tls-mode=off
fi

phase_step "seeding fixture users"
pg_seed_users

phase_step "seeding e2e-fixed devices for alice and bob"
# The Playwright spec uses pinned device UUIDs that we ensure exist
# here. Without these, the ensureDeviceForTesting shim would tie them
# both to alice; we want bob's device to belong to bob.
if [ "$CHALK_DRY_RUN" != "1" ]; then
  # shellcheck disable=SC2154
  psql "$CHALK_TEST_PGURL" <<'SQL'
INSERT INTO devices (id, user_id, device_type, device_label)
VALUES
  ('11111111-1111-1111-1111-111111111111',
   '00000000-0000-0000-0000-00000000a11c',
   'desktop', 'phase-08b-e2e-alice')
ON CONFLICT (id) DO UPDATE
  SET user_id = EXCLUDED.user_id, device_label = EXCLUDED.device_label;

INSERT INTO devices (id, user_id, device_type, device_label)
VALUES
  ('22222222-2222-2222-2222-222222222222',
   '00000000-0000-0000-0000-000000000b0b',
   'desktop', 'phase-08b-e2e-bob')
ON CONFLICT (id) DO UPDATE
  SET user_id = EXCLUDED.user_id, device_label = EXCLUDED.device_label;

-- Seed alice<->bob friendship so the create modal's friend picker
-- shows bob to alice.
INSERT INTO friendships (user_a, user_b, status, requested_at, accepted_at)
VALUES (
  LEAST(
    '00000000-0000-0000-0000-00000000a11c'::uuid,
    '00000000-0000-0000-0000-000000000b0b'::uuid
  ),
  GREATEST(
    '00000000-0000-0000-0000-00000000a11c'::uuid,
    '00000000-0000-0000-0000-000000000b0b'::uuid
  ),
  'accepted', now(), now()
) ON CONFLICT (user_a, user_b) DO UPDATE
  SET status = 'accepted', accepted_at = now();
SQL
fi

phase_step "starting chalkd #1"
server_up_n 1

phase_step "starting chalkd #2"
server_up_n 2

phase_step "running phase 08a integration tests (channel_test.go) against new backend"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  cd "$CHALK_REPO_ROOT"
  CHALK_TEST_PGURL="$CHALK_TEST_PGURL" \
  CHALK_TEST_HTTP_1="$CHALK_TEST_HTTP_1" \
  CHALK_TEST_HTTP_2="$CHALK_TEST_HTTP_2" \
    go test -race -count=1 -v ./test/integration/ -run 'TestPhase08_' -timeout=60s
fi

phase_step "installing playwright (already cached from phase 07)"
e2e_install

phase_step "running phase 08b Playwright spec"
if [ "$CHALK_DRY_RUN" != "1" ]; then
  cd "$CHALK_REPO_ROOT/test/e2e"
  CHALK_TEST_HTTP_1="$CHALK_TEST_HTTP_1" \
  CHALK_TEST_HTTP_2="$CHALK_TEST_HTTP_2" \
    npx playwright test channels.spec.ts --reporter=line
fi

phase_step "stopping chalkds"
server_stop_n 1
server_stop_n 2

phase_step "tearing down ephemeral postgres"
pg_stop_ephemeral
trap - EXIT

phase_step "committing"
git_commit_phase "$PHASE" "$PHASE_NAME (08b SPA)"

phase_done "$PHASE"
